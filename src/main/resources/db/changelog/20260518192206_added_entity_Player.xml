<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.5.xsd">
    <changeSet id="20260518192206" author="brian">
        <createTable tableName="tbl_players">
            <column name="id" type="bigint" autoIncrement="${autoIncrement}">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" />
            </column>
            <column name="icon_url" type="varchar(500)"/>
            <column name="date_of_birth" type="date">
                <constraints nullable="true"/>
            </column>
            <column name="country" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="current_club" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="position" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
            <column name="jersey_number" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="alumni" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="tbl_players" baseColumnNames="current_club" constraintName="fk_player_club" referencedTableName="tbl_clubs"
                                 referencedColumnNames="id"/>
    </changeSet>
    <changeSet id="20260519171018" author="brian">
        <loadData tableName="tbl_players" file="db/changelog/data/players/afc.csv" separator=","  relativeToChangelogFile="false"/>
    </changeSet>
</databaseChangeLog>